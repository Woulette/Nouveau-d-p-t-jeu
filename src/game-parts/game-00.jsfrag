    forestCharm: { id: 'forestCharm', name: 'Charme forestier', description: '+2 magie et +5 PM.', icon: 'orb', type: 'equipment', slot: 'charm', stats: { magic: 2, maxMp: 5 }, rarity: 'rare' },
