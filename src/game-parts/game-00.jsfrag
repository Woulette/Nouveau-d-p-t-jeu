  };

  const DEFAULT_SAVE = {
    version: 1,
    player: {
      name: 'Voyageur 801', x: 24, y: 22, level: 1, xp: 0, className: 'Aventurier', classLevel: 1, classXp: 0,
      hp: 100, baseMaxHp: 100, mp: 40, baseMaxMp: 40, gold: 0, weapon: 'staff', village: 'Village de Solenne'
    },
